<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="18dp"
    tools:context=".QuizActivity">

    <LinearLayout
        android:id="@+id/question_block"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/answers_grid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/place_image"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/place_image_description"
            android:src="@drawable/ic_quiz_place" />

        <TextView
            android:id="@+id/place_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="Москва" />

        <TextView
            android:id="@+id/question_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            tools:text="Какой объект находится рядом с этим маркером?" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/answers_grid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:useDefaultMargins="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btn_a"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/answer_default"
            android:onClick="answerA"
            android:textColor="@color/answer_default_text"
            tools:text="Ответ A" />

        <Button
            android:id="@+id/btn_b"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/answer_default"
            android:onClick="answerB"
            android:textColor="@color/answer_default_text"
            tools:text="Ответ B" />

        <Button
            android:id="@+id/btn_c"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/answer_default"
            android:onClick="answerC"
            android:textColor="@color/answer_default_text"
            tools:text="Ответ C" />

        <Button
            android:id="@+id/btn_d"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/answer_default"
            android:onClick="answerD"
            android:textColor="@color/answer_default_text"
            tools:text="Ответ D" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
