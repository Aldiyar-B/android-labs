<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Работа с базой данных"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnStudents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Показать студентов" />

    <Button
        android:id="@+id/btnSubjects"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Показать дисциплины"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnGrades"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Показать оценки"
        android:layout_marginTop="8dp" />

    <ListView
        android:id="@+id/listDB"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

</LinearLayout>